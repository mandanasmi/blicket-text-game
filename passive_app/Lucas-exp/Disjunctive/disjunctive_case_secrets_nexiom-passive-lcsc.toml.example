# Disjunctive case app (`passive_app/disjunctive_case_app.py`) — Firebase Admin SDK for project **nexiom-passive-lcsc-disj**
#
# Uses the **disjunctive** Realtime Database instance (URL ends in `...-disj-default-rtdb...`), not the default instance.
# Same service account as other lcsc apps; you must still add private_key_id and private_key from a generated JSON.
#
# Copy to `.streamlit/secrets.toml` (local, gitignored) or paste `[firebase]` into Streamlit Cloud → Secrets.

[firebase]
# Must match the Firebase project id (not "lcsd" — that is a common typo for lcsc).
project_id = "nexiom-passive-lcsc-disj"
private_key_id = "PLACEHOLDER_private_key_id"
private_key = "-----BEGIN PRIVATE KEY-----\nPLACEHOLDER_PASTE_MULTILINE_KEY_WITH_ESCAPED_NEWLINES\n-----END PRIVATE KEY-----\n"
client_email = "firebase-adminsdk-fbsvc@nexiom-passive-lcsc.iam.gserviceaccount.com"
client_id = "112037596072780580056"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40nexiom-passive-lcsc.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
# Disjunctive dataset: separate RTDB instance in the same project (confirm URL in Console → Realtime Database).
database_url = "https://nexiom-passive-lcsc-disj-default-rtdb.firebaseio.com"
