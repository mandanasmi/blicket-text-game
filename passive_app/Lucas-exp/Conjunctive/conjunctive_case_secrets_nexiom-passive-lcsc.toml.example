# Conjunctive case app (`passive_app/conjunctive_case_app.py`) — Firebase Admin SDK for project **nexiom-passive-lcsc**
#
# The JavaScript web config (apiKey, appId, …) is NOT enough for Streamlit: you must add a
# **service account** from Firebase Console → Project settings → Service accounts → Generate new private key.
#
# Copy this file to the repo root as `.streamlit/secrets.toml` (local, gitignored) or paste the
# `[firebase]` block into Streamlit Cloud → App → Settings → Secrets.
#
# Replace PLACEHOLDER_* fields from your service account JSON (never commit real keys).
# If a key was ever pasted in chat or committed, delete that key in GCP and generate a new one.

[firebase]
project_id = "nexiom-passive-lcsc"
private_key_id = "PLACEHOLDER_private_key_id"
private_key = "-----BEGIN PRIVATE KEY-----\nPLACEHOLDER_PASTE_MULTILINE_KEY_WITH_ESCAPED_NEWLINES\n-----END PRIVATE KEY-----\n"
# Default Firebase Admin SDK email for this project (fixed; not the secret):
client_email = "firebase-adminsdk-fbsvc@nexiom-passive-lcsc.iam.gserviceaccount.com"
client_id = "PLACEHOLDER_client_id"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40nexiom-passive-lcsc.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
# Realtime Database URL — copy from Console: Build → Realtime Database (must contain firebaseio.com or firebasedatabase.app)
database_url = "https://nexiom-passive-lcsc-default-rtdb.firebaseio.com"
